{
  "name": "sidekick",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "cd src/web && npx vite --port 5173",
    "dev:desktop": "concurrently -n web,electron -c green,magenta \"npm run dev:web\" \"sleep 2 && electron . --dev\"",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.2.1",
    "nanoid": "^5.1.2",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
