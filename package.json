{
  "name": "sidekick",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "cd src/web && npx vite --port 5173",
    "dev:desktop": "concurrently -n web,electron -c green,magenta \"npm run dev:web\" \"sleep 2 && unset ELECTRON_RUN_AS_NODE && electron . --dev\"",
    "start": "unset ELECTRON_RUN_AS_NODE && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp": "tsx src/mcp/index.ts",
    "build:web": "cd src/web && npx vite build",
    "rebuild:electron": "npx @electron/rebuild -f -m . -o better-sqlite3",
    "build:app": "npm run build:web && npm run rebuild:electron && electron-builder --mac && plutil -remove ElectronAsarIntegrity release/mac/Sidekick.app/Contents/Info.plist && npm rebuild better-sqlite3",
    "build": "npm run build:app",
    "install:app": "npm run build && rm -rf /Applications/Sidekick.app && cp -R release/mac/Sidekick.app /Applications/Sidekick.app && xattr -cr /Applications/Sidekick.app"
  },
  "build": {
    "appId": "com.theoddstack.sidekick",
    "productName": "Sidekick",
    "asar": false,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dir",
      "icon": "assets/icon.icns",
      "identity": null
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.2.1",
    "nanoid": "^5.1.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
